{
    "version": 4,
    "configurations": [
        {
            "name": "Linux-g++-15",
            "compilerPath": "/usr/bin/g++-15",
            "cStandard": "c11",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/../dependencies/glfw/include",
                "/usr/include",
                "/usr/local/include"
            ],
            "defines": [
                "STB_IMAGE_IMPLEMENTATION",
                "_CRT_SECURE_NO_WARNINGS",
                "STB_IMAGE_WRITE_IMPLEMENTATION",
                "WINDOW",
                "MOUSE",
                "KEYBOARD",
                "GAMEPAD",
                "GLFW_WINDOW",
                "GLFW_MOUSE",
                "GLFW_KEYBOARD",
                "GLFW_GAMEPAD"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "/usr/include",
                    "/usr/local/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}